# Copy to .env for local use. Keep real keys out of git.
GROQ_API_KEY=
OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=
AI_CTO_VOICE_BRAIN=groq

# Optional Gmail/Calendar OAuth.
# Put the OAuth client-secret JSON at .run/google-client-secret.json, or point here.
AI_CTO_GOOGLE_CLIENT_SECRET=.run/google-client-secret.json
AI_CTO_GOOGLE_TOKEN=
